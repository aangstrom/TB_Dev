            } ],
            "showTitle" : false,
            "backgroundColor" : "#fff",
            "color" : "rgba(0, 0, 0, 0.87)",
            "padding" : "0",
            "settings" : {
              "useMarkdownTextFunction" : true,
              "markdownTextPattern" : "return `\r\n<div class=\"menu transparent-bg\">\r\n  <div class=\"content\">\r\n    ${\r\n      (data[0].visualizzazione_corsia_fiera == \"immagine\")\r\n        ? \"<button id='immagine' class='menu-btn active'>Image</button>\"\r\n        : \"<button id='immagine' class='menu-btn'>Image</button>\"\r\n    }\r\n    ${\r\n      (data[0].visualizzazione_corsia_fiera == \"lista\")\r\n        ? \"<button id='lista' class='menu-btn active'>Shelf list</button>\"\r\n        : \"<button id='lista' class='menu-btn'>Shelf list</button>\"\r\n    }\r\n    ${\r\n      (data[0].visualizzazione_corsia_fiera == \"dati\")\r\n        ? \"<button id='dati' class='menu-btn active'>Environmental Data</button>\"\r\n        : \"<button id='dati' class='menu-btn'>Environmental Data</button>\"\r\n    }\r\n    ${\r\n      (data[0].visualizzazione_corsia_fiera == \"utilizzo\")\r\n        ? \"<button id='utilizzo' class='menu-btn active'>Aisle Usage</button>\"\r\n        : \"<button id='utilizzo' class='menu-btn'>Aisle Usage</button>\"\r\n    }\r\n    ${\r\n      (data[0].visualizzazione_corsia_fiera == \"allarmi\")\r\n        ? \"<button id='allarmi' class='menu-btn active'>Alarms</button>\"\r\n        : \"<button id='allarmi' class='menu-btn'>Alarms</button>\"\r\n    }\r\n  </div>\r\n</div>\r\n`;\r\n",
              "markdownTextFunction" : "console.log(data);\r\nreturn `\r\n<div class=\"menu transparent-bg\">\r\n  <div class=\"content\">\r\n    ${\r\n      (data[0].visualizzazione == \"chat\" || data[0].visualizzazione == \"\")\r\n        ? \"<button id='chat' class='menu-btn active'>Chat</button>\"\r\n        : \"<button id='chat' class='menu-btn'>Chat</button>\"\r\n    }\r\n    ${\r\n      (data[0].visualizzazione == \"devices\")\r\n        ? \"<button id='devices' class='menu-btn active'>Devices</button>\"\r\n        : \"<button id='devices' class='menu-btn'>Devices</button>\"\r\n    }\r\n  </div>\r\n</div>\r\n`;\r\n",
              "applyDefaultMarkdownStyle" : true,
              "markdownCss" : ".transparent-bg {\r\n  background: transparent !important;\r\n}\r\n\r\n/* Layout */\r\n.menu {\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  width: 100%;\r\n  height: 100%;\r\n}\r\n\r\n.content {\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  gap: 0.8vw; /* slightly tighter */\r\n  flex-wrap: nowrap;\r\n}\r\n\r\n/* --- Modern Button Style (Light Theme, Compact + Responsive) --- */\r\n.menu-btn {\r\n  width: 11.5vw;               /* narrower base */\r\n  min-width: 110px;\r\n  max-width: 190px;\r\n\r\n  height: 3.6vw;\r\n  min-height: 40px;\r\n  max-height: 60px;\r\n\r\n  font-family: \"Inter\", \"Segoe UI\", Roboto, sans-serif;\r\n  font-size: 0.9vw;\r\n  min-font-size: 0.85rem;\r\n  max-font-size: 1rem;\r\n\r\n  font-weight: 500;\r\n  letter-spacing: 0.15px;\r\n\r\n  color: #1e293b;\r\n  background: #f8fafc;\r\n  border: 1px solid rgba(0, 0, 0, 0.08);\r\n  border-radius: 14px;\r\n\r\n  cursor: pointer;\r\n  user-select: none;\r\n  transition: all 0.25s ease;\r\n  box-shadow: 0 3px 10px rgba(0, 0, 0, 0.08);\r\n}\r\n\r\n/* Hover effect */\r\n.menu-btn:hover {\r\n  background: #f1f5f9;\r\n  transform: translateY(-2px);\r\n  box-shadow: 0 6px 16px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n/* Active (selected) */\r\n.menu-btn.active {\r\n  background: linear-gradient(145deg, #e0f2fe, #bfdbfe);\r\n  border-color: #3b82f6;\r\n  color: #1e3a8a;\r\n  font-weight: 600;\r\n  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.25),\r\n              0 6px 16px rgba(59, 130, 246, 0.15);\r\n}\r\n\r\n/* Press feedback */\r\n.menu-btn:active {\r\n  transform: translateY(0);\r\n  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);\r\n}\r\n\r\n/* Focus ring */\r\n.menu-btn:focus-visible {\r\n  outline: none;\r\n  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.35),\r\n              0 0 0 6px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n/* --- Compression when ThingsBoard panel gets thinner --- */\r\n@media (max-width: 1100px) {\r\n  .menu-btn {\r\n    width: 9.5vw;\r\n    height: 3.2vw;\r\n    font-size: 0.85vw;\r\n  }\r\n  .content {\r\n    gap: 0.6vw;\r\n  }\r\n}\r\n\r\n@media (max-width: 800px) {\r\n  .menu-btn {\r\n    width: 8.2vw;\r\n    height: 3vw;\r\n    font-size: 0.8vw;\r\n  }\r\n  .content {\r\n    gap: 0.5vw;\r\n  }\r\n}\r\n\r\n@media (max-width: 600px) {\r\n  .menu-btn {\r\n    width: 7vw;\r\n    height: 2.8vw;\r\n    font-size: 0.75vw;\r\n  }\r\n  .content {\r\n    gap: 0.4vw;\r\n  }\r\n}\r\n\r\n"
            },
