        "ba8e98e7-7ecb-0e90-2ae4-a3c3aa1294b2" : {
          "typeFullFqn" : "system.cards.markdown_card",
          "type" : "latest",
          "sizeX" : 5,
          "sizeY" : 3.5,
          "config" : {
            "datasources" : [ {
              "type" : "entity",
              "name" : "",
              "entityAliasId" : "8fac79c1-aef2-3fc8-300a-3f32972ba7f6",
              "dataKeys" : [ {
                "name" : "visualizzazione",
                "type" : "attribute",
                "label" : "visualizzazione",
                "color" : "#2196f3",
                "settings" : { }
              } ],
              "alarmFilterConfig" : {
