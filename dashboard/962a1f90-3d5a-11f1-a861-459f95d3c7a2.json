            "padding" : "0",
            "settings" : {
              "useMarkdownTextFunction" : true,
              "markdownTextPattern" : "var scaffale,corsia,armadio,impianto,antincendio,antintrusione,climatizzazione,vibrazione,tred,realtime,system,CNR;\nif (data && data.length && data[0].entityId) {\n    if(data[0].Type==\"Scaffale\"){\n        scaffale=true;\n    }\n    if(data[0].Type==\"Corsia\"){\n        corsia=true;\n    }\n    if(data[0].Type=='Armadio'){\n        armadio=true;\n    }\n    if(data[0].Type=='Impianto'){\n        impianto=true;\n    }\n    if(data[0].Type=='Antincendio'){\n        antincendio=true;\n    }\n    if(data[0].Type=='AntiIntrusione'){\n        antintrusione=true;\n    }\n    if(data[0].Type=='Climatizzazione'){\n        climatizzazione=true;\n    }\n    if(data[0].Type=='Vibrazione'){\n        vibrazione=true;\n    }\n    if(data[0].Type=='Realtime'){\n        realtime=true;\n    }\n    if(data[0].Type=='System'){\n        system=true;\n    }\n    if(data[0].Type=='3D'){\n        tred=true;\n    }\n    if(data[0].Type=='CNR'){\n        CNR=true;\n    }\n} else {\n    scaffale = false;\n    corsia = false;\n    armadio = false;\n    impianto = false;\n    antincendio = false;\n    antintrusione = false;\n    climatizzazione = false;\n    vibrazione = false;\n    tred = false;\n    realtime = false;\n    system = false;\n}\nreturn '<div class=\"main-layout\" style=\"width: 100%; height:100%;\" fxLayout=\"column\">' +\n    (\n        scaffale==true ? ('<tb-dashboard-state fxFlex [ctx]=\"ctx\" stateId=\"page_scaffale\"></tb-dashboard-state></div>') :\n        corsia==true ? ('<tb-dashboard-state fxFlex [ctx]=\"ctx\" stateId=\"page_corsia\"></tb-dashboard-state></div>') :\n        armadio==true ? ('<tb-dashboard-state fxFlex [ctx]=\"ctx\" stateId=\"page_armadio\"></tb-dashboard-state></div>') :\n        impianto==true ? ('<tb-dashboard-state fxFlex [ctx]=\"ctx\" stateId=\"page_mappa\"></tb-dashboard-state></div>') :\n        \n        antincendio==true ? ('<tb-dashboard-state fxFlex [ctx]=\"ctx\" stateId=\"page_antincendio\"></tb-dashboard-state></div>') :\n        antintrusione==true ? ('<tb-dashboard-state fxFlex [ctx]=\"ctx\" stateId=\"page_antintrusione\"></tb-dashboard-state></div>') :\n        climatizzazione==true ? ('<tb-dashboard-state fxFlex [ctx]=\"ctx\" stateId=\"page_hvac\"></tb-dashboard-state></div>') :\n        vibrazione==true ? ('<tb-dashboard-state fxFlex [ctx]=\"ctx\" stateId=\"page_vibrazione\"></tb-dashboard-state></div>') :\n        tred==true ? ('<tb-dashboard-state fxFlex [ctx]=\"ctx\" stateId=\"page_3D\"></tb-dashboard-state></div>') :\n        \n        realtime==true ? ('<tb-dashboard-state fxFlex [ctx]=\"ctx\" stateId=\"page_realtime\"></tb-dashboard-state></div>') :\n        system==true ? ('<tb-dashboard-state fxFlex [ctx]=\"ctx\" stateId=\"page_impianto\"></tb-dashboard-state></div>') :\n        CNR==true ? ('<tb-dashboard-state fxFlex [ctx]=\"ctx\" stateId=\"page_cnr\"></tb-dashboard-state></div>') :\n        ('<tb-dashboard-state fxFlex [ctx]=\"ctx\" stateId=\"page_mappa\"></tb-dashboard-state></div>')\n    );",
              "markdownTextFunction" : "var chat,devices;\nif (data && data.length && data[0].entityId) {\n    if(data[0].visualizzazione==\"chat\"){\n        chat=true;\n    }\n    if(data[0].visualizzazione==\"devices\"){\n        devices=true;\n    }\n} else {\n    chat = false;\n    devices = false;\n}\nreturn '<div class=\"main-layout\" style=\"width: 100%; height:100%;\" fxLayout=\"column\">' +\n    (\n        chat==true ? ('<tb-dashboard-state fxFlex [ctx]=\"ctx\" stateId=\"chat\"></tb-dashboard-state></div>') :\n        devices==true ? ('<tb-dashboard-state fxFlex [ctx]=\"ctx\" stateId=\"devices\"></tb-dashboard-state></div>') :\n        ('<tb-dashboard-state fxFlex [ctx]=\"ctx\" stateId=\"chat\"></tb-dashboard-state></div>')\n    );",
              "applyDefaultMarkdownStyle" : false,
              "markdownCss" : ""
